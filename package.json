{
  "name": "protonmail-agentic-mcp",
  "version": "2.0.3",
  "description": "ProtonMail Agentic MCP — 51 tools, Resources, and Prompts for agentic email management, folder operations, analytics, and Proton Bridge integration.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "protonmail-agentic-mcp": "dist/index.js",
    "protonmail-agentic-mcp-settings": "dist/settings-main.js"
  },
  "scripts": {
    "build": "tsc",
    "settings": "node dist/settings-main.js",
    "build:clean": "npm run clean && npm run build",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build:clean && npm run lint && npm run test",
    "lint": "tsc --noEmit",
    "lint:fix": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "protonmail",
    "proton",
    "mcp",
    "model-context-protocol",
    "email",
    "email-management",
    "automation",
    "typescript",
    "claude",
    "claude-desktop",
    "ai",
    "productivity",
    "bridge",
    "proton-bridge",
    "smtp",
    "imap",
    "analytics",
    "email-analytics",
    "email-automation"
  ],
  "author": {
    "name": "Charles Handshy",
    "email": "chandshy@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/chandshy/protonmail-agentic-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chandshy/protonmail-agentic-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/chandshy/protonmail-agentic-mcp/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.27.1",
    "imapflow": "~1.2.15",
    "mailparser": "~3.9.4",
    "nodemailer": "~8.0.2"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "~1.2.0",
    "systray2": "~2.1.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^6.4.19",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "package.json"
  ],
  "overrides": {
    "fast-xml-parser": ">=5.5.6"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
